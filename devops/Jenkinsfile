pipeline {
    // Exécute le pipeline sur n'importe quel agent Jenkins disponible
    agent any

    // Définition des variables d'environnement globales pour le pipeline
    environment {
        // L'outil Maven configuré dans Jenkins (Doit correspondre au nom dans Global Tool Configuration)
        MAVEN_TOOL = 'Maven 3'
        
        // Nom de l'image Docker
        IMAGE_NAME = 'mon-entreprise/mon-app-springboot'
        
        // On utilise l'ID du commit Git comme tag pour tracer exactement quelle version du code tourne
        IMAGE_TAG = "${env.BUILD_ID}" 
    }

    stages {
        
        // ------------------------------------------------------------
        // ÉTAPE 1 : Récupération du Code
        // ------------------------------------------------------------
        stage('Checkout') {
            steps {
                echo 'Récupération du code source depuis Git...'
                checkout scm
            }
        }

        // ------------------------------------------------------------
        // ÉTAPE 2 : Compilation et Tests Unitaires
        // ------------------------------------------------------------
        stage('Build & Tests') {
            steps {
                echo 'Compilation du projet avec Maven...'
                // On utilise 'withMaven' pour charger la conf globale (si configuré avec le plugin)
                // Ou simplement appeler l'exécutable local
                sh './mvnw clean package -DskipTests=false'
            }
            post {
                always {
                    // Enregistre les résultats des tests JUnit (Fichiers XML) dans l'interface Jenkins
                    echo "junit deactivated"
                }
            }
        }

        // ------------------------------------------------------------
        // ÉTAPE 3 : Analyse de Qualité du Code avec SonarQube
        // ------------------------------------------------------------
        stage('SonarQube Analysis') {
            steps {
                echo 'Lancement de l\'analyse de qualité...'
                // 'SonarQube' doit correspondre au nom du serveur configuré dans Jenkins
                withSonarQubeEnv('SonarQube') {
                    // Le plugin Maven pour Sonar envoie l'analyse au serveur
                    sh './mvnw sonar:sonar'
                }
            }
        }

        // ------------------------------------------------------------
        // ÉTAPE 4 : Quality Gate (Optionnel mais recommandé)
        // ------------------------------------------------------------
        stage('Quality Gate') {
            steps {
                // Attendre la réponse de SonarQube. Si le code contient trop de bugs (selon les règles), 
                // le pipeline échoue ici et empêche une mise en production d'un code défectueux.
                timeout(time: 5, unit: 'MINUTES') {
                    // Requires 'SonarQube Scanner for Jenkins' plugin webhook to be configured
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        // ------------------------------------------------------------
        // ÉTAPE 5 : Construction de l'image Docker (Build)
        // ------------------------------------------------------------
        stage('Docker Build') {
            steps {
                echo "Construction de l'image Docker : ${IMAGE_NAME}:${IMAGE_TAG}"
                // Jenkins utilise le Dockerfile présent à la racine du projet
                sh "docker build -t ${IMAGE_NAME}:${IMAGE_TAG} ."
                // On tag aussi en 'latest' pour toujours avoir la dernière version facilement accessible
                sh "docker tag ${IMAGE_NAME}:${IMAGE_TAG} ${IMAGE_NAME}:latest"
            }
        }

        // ------------------------------------------------------------
        // ÉTAPE 6 : Pousser l'image vers le Registre (Docker Hub, Harbor, etc.)
        // ------------------------------------------------------------
        stage('Docker Push') {
            steps {
                // 'docker-credentials-id' est l'ID du secret stocké en sécurité dans Jenkins
                withCredentials([usernamePassword(credentialsId: 'docker-credentials-id', passwordVariable: 'DOCKER_PASS', usernameVariable: 'DOCKER_USER')]) {
                    echo "Connexion au registre Docker..."
                    sh "echo \$DOCKER_PASS | docker login -u \$DOCKER_USER --password-stdin"
                    
                    echo "Push des images vers le registre..."
                    sh "docker push ${IMAGE_NAME}:${IMAGE_TAG}"
                    sh "docker push ${IMAGE_NAME}:latest"
                }
            }
        }

        // ------------------------------------------------------------
        // ÉTAPE 7 : Déploiement sur Kubernetes
        // ------------------------------------------------------------
        stage('Kubernetes Deploy') {
            steps {
                echo "Déploiement de la version ${IMAGE_TAG} sur le cluster Kubernetes..."
                // On utilise le kubeconfig stocké dans Jenkins pour avoir le droit de parler au cluster
                withKubeConfig([credentialsId: 'k8s-credentials-id']) {
                    
                    // On modifie à la volée le fichier deployment.yaml pour y injecter le bon tag Docker (IMAGE_TAG)
                    // (L'outil 'sed' remplace un marqueur par la variable Jenkins)
                    sh "sed -i 's/APP_VERSION_TAG/${IMAGE_TAG}/g' k8s/deployment.yaml"
                    
                    // "kubectl apply" crée ou met à jour les ressources sur le cluster
                    sh "kubectl apply -f k8s/deployment.yaml"
                    sh "kubectl apply -f k8s/service.yaml"
                    
                    // On peut vérifier le statut du déploiement
                    sh "kubectl rollout status deployment/spring-boot-app"
                }
            }
        }
    }

    // ------------------------------------------------------------
    // ACTIONS POST-PIPELINE (Notifications)
    // ------------------------------------------------------------
    post {
        success {
            echo "✅ Pipeline terminé avec SUCCÈS. L'application est en production !"
            // On pourrait envoyer un message Slack, Teams ou un Email ici
        }
        failure {
            echo "❌ Le pipeline a ÉCHOUÉ."
        }
    }
}
